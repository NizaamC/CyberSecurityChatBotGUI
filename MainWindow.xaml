<Window x:Class="CyberSecurityChatBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Bot"
        Height="600"
        Width="900"
        Background="#101820">

    <Grid>

        <!-- HEADER -->
        <Border Background="#00ADB5"
                Height="80"
                VerticalAlignment="Top">

            <TextBlock Text="🛡 CYBERSECURITY AWARENESS BOT"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- CHAT AREA -->
        <Border Margin="20,100,20,100"
                Background="#1B262C"
                CornerRadius="10">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ChatDisplay"
                           Margin="15"
                           Foreground="White"
                           FontSize="16"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- INPUT AREA -->
        <Grid VerticalAlignment="Bottom"
              Height="70"
              Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- USER INPUT -->
            <TextBox x:Name="UserInput"
                     BorderThickness="0"
                     Grid.Column="0"
                     FontSize="16"
                     Margin="0,0,10,0"
                     Background="#EEEEEE"
                     Foreground="Black"
                     VerticalContentAlignment="Center"
                     Padding="10"/>

            <!-- SEND BUTTON -->
            <Button x:Name="SendButton"
                    Cursor="Hand"
                    BorderThickness="0"
                    Grid.Column="1"
                    Content="Send"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#00ADB5"
                    Foreground="White"
                    Click="SendButton_Click"/>
        </Grid>

    </Grid>
</Window>
